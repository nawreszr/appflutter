# PostgreSQL Configuration
POSTGRES_DB=etudiants_db
POSTGRES_USER=etudiants_user
POSTGRES_PASSWORD=etudiants_password
POSTGRES_PORT=5432

# Spring Boot Configuration
SPRING_PORT=8080
SPRING_ENVIRONMENT=dev

# Application Configuration
APP_NAME=API Étudiants
APP_VERSION=1.0.0

# Flutter Mobile App
FLUTTER_API_URL=http://192.168.x.x:8080/api/etudiants
# Replace 192.168.x.x with your machine IP address
